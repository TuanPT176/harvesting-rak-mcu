<mxfile host="app.diagrams.net">
  <diagram name="Firmware Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Wake Up" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Read PMIC -->
        <mxCell id="pmic" value="Read PMIC&#10;(VBAT + Current)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Sensor -->
        <mxCell id="sensor" value="Read Sensor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="250" y="180" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Ensure Config -->
        <mxCell id="config" value="Ensure PMIC Config&#10;(OVP, LVD, Reg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="250" y="260" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Make Decision&#10;(VBAT + Current)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="275" y="340" width="150" height="80" as="geometry"/>
        </mxCell>

        <!-- Update Frequency -->
        <mxCell id="freq" value="Update Frequency&#10;(Adaptive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="250" y="440" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- LoRa -->
        <mxCell id="lora" value="Send LoRa (optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="250" y="520" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Sleep -->
        <mxCell id="sleep" value="Sleep (10–60 min)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="300" y="600" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell edge="1" parent="1" source="start" target="pmic"/>
        <mxCell edge="1" parent="1" source="pmic" target="sensor"/>
        <mxCell edge="1" parent="1" source="sensor" target="config"/>
        <mxCell edge="1" parent="1" source="config" target="decision"/>
        <mxCell edge="1" parent="1" source="decision" target="freq"/>
        <mxCell edge="1" parent="1" source="freq" target="lora"/>
        <mxCell edge="1" parent="1" source="lora" target="sleep"/>
        <mxCell edge="1" parent="1" source="sleep" target="start"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>